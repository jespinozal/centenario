<apex:page applyHtmlTag="false" showHeader="false" renderAs="PDF" standardController="Account" extensions="CEN_cls_AccountController" >

        
    <style>
			/* cuando vayamos a imprimir ... */
				@media print{
				/* indicamos el salto de pagina */
				.saltoDePagina{
				display:block;
				page-break-before:always;
			}
		}
		</style>
     
    <style type="text/css" media="print">
            @page {            
              size: A4;
              margin-top: 50px;
              margin-bottom: 70px;
            
			  margin-left: 20px;
              margin-right: 20px;
            
              @top-right {
                font-size:80%;
            	content: "Página " counter(page)  " de " counter(pages);

              }
            
              @top-left {
                font-size:80%;
                content: element(header);
              }
            
              @top-center{
                content: element(header);
              }
            }
            
            body{
                counter-reset: page;
            }

            #pageNumber::before{ 
                counter-increment: page;
                content: counter(page);
            }

            .anidado::before{
                counter-increment: ani;
                content: counter(ani) ;
            }
            
            .planTrabajo{
                counter-reset: p;
            }
            
            .indice::before{
                counter-increment: p;
                content: counter(p) " ";
            }

	        p.saltodepagina
            
			{
				page-break-after: always;
			}

			dt {
   				float: left;
    			clear: left;
    			width: 25px;
    			text-align: right;
    			font-weight: bold;    
  			}
            
  			dt::after {
    			content: "";
  			}
  
            dd {    
    			padding: 0 0 0.1em 0;
    			margin-left: 60px;
  			}

			.contenidos {
                display: table-row;
                border: 0px solid #000;
			}
            
			.columna1, .columna2, .columna3 {
                display: table-cell;
                border: 0px solid #000;
                vertical-align: bottom;
                padding:0.9px;
                text-align: left;
                margin-left: 0.5px;
			}
         
            .inner {
                display: table;
                margin: 0 auto;
                border: 1px solid black;
            }

            .outer {
                border: 1px solid red;
                width:100%
            }
            
            #footer{
             position:fixed;
             bottom:0;
             left:0;
            }
           
        
    	</style>  
    
    <style type="text/css">
        
     @import url('https://fonts.googleapis.com/css?family=Ubuntu');
               
        
     </style>       
    
    <div style="width: 100%; height: 20%;">
        <div style="width: 40%; float:left;">
            
            <div style="border: 1px dashed black; width: 100%; padding: 1% 0% 1% 0%; -webkit-border-radius: 10px; -moz-border-radius: 10px; border-radius: 10px">
            	<span style="color:#000; font-family: 'Ubuntu', sans-serif; padding:5%">Fecha:</span>
                <apex:outputText value="{0,date,dd'/'MM'/'yyyy}"><apex:param value="{!TODAY()}" /></apex:outputText>
        	</div>
            <br/>
            <div style="border: 1px dashed black; width: 100%; padding: 1% 0% 1% 0%; -webkit-border-radius: 10px; -moz-border-radius: 10px; border-radius: 10px; text-align: left">
                <span style="color:#000; font-family: 'Ubuntu', sans-serif; padding:5%">Medio:&nbsp;&nbsp;{!Account.CEN_Medio__c}</span>
        	</div>
                                                            
        </div>

        <div style="width: 20%; display:inline-block">
        </div>

        <div style="width: 50%; float: right; background: rgb(188,9,35); background: linear-gradient(50deg, rgba(188,9,35,1) 33%, rgba(224,1,9,1) 100%); padding: 1% 0% 1% 0%;">
            <span style="color:#FFFFFF; font-family: 'Ubuntu', sans-serif; padding:25%">Formulario de datos</span>
        </div>
    </div>
    
    <br /><br /><br />
                
    <body>
        
        <div style="width: 100%; height: 20%; text-align: center; position: absolute">
        <img src="{!$Resource.CEN_sr_logoCentenario}" width="250" height="180"/>       
   		</div>
        
       <br/><br /><br /><br /><br /><br /><br /><br /><br />    
        <div style="width: 100%; height:50px; border: 1px dashed black">
            <div style="float:left;">
                <img src="{!$Resource.persona}" width="50" height="50"/>
            </div>
             <div style="float:left; vertical-align: middle; padding-top: 0.4%;">
                 <span style="font-family: 'Ubuntu', sans-serif;">Nombres <br/> y apellidos:&nbsp;&nbsp;{!Account.Name}</span>
            </div>            
        </div>
        
        <br/>        
        <div style="width: 100%; height:50px; border: 1px dashed black">
            <div style="float:left;">
                <img src="{!$Resource.dni}" width="50" height="50"/>
            </div>
             <div style="float:left; display: table-cell; vertical-align: middle; padding-top:2.3%">
                 <span style="font-family: 'Ubuntu', sans-serif;">{!Account.CEN_Tipo_de_documento__pc}: &nbsp;&nbsp;{!Account.CEN_N_mero_de_documento__pc}</span>
            </div>            
        </div>
        
        <br/>        
        <div style="width: 100%; height:50px; border: 1px dashed black">
            <div style="float:left;">
                <img src="{!$Resource.direccion}" width="50" height="50"/>
            </div>
             <div style="float:left; display: table-cell; vertical-align: middle; padding-top:2.3%">
                 <span style="font-family: 'Ubuntu', sans-serif;">Distrito: &nbsp;&nbsp;{!Account.CEN_Distrito__r.Name}</span>
            </div>            
        </div>
        
        <br/>        
        <div style="width: 100%; height:50px; border: 1px dashed black">
            <div style="float:left;">
                <img src="{!$Resource.celular}" width="50" height="50"/>
            </div>
             <div style="float:left; display: table-cell; vertical-align: middle; padding-top:2.3%">                 
                 <span style="font-family: 'Ubuntu', sans-serif;">Número de contacto: &nbsp;&nbsp;{!Account.Phone}</span>
            </div>            
        </div>
        
        <br/>        
        <div style="width: 100%; height:50px; border: 1px dashed black">
            <div style="float:left;">
                <img src="{!$Resource.email}" width="50" height="50"/>
            </div>
             <div style="float:left; display: table-cell; vertical-align: middle; padding-top:2.3%">
                 <span style="font-family: 'Ubuntu', sans-serif;">E-mail: &nbsp;&nbsp;{!Account.PersonEmail}</span>
            </div>            
        </div>
        
        <br/> 
        
        <div style="width:100%;height: 50px;">
            <div style="width: 30%; height:50px; border: 1px dashed black; float:right">                       
            </div> 
        </div> 
        
        <br />
        
        <div style="width: 100%; height:50px;">
        <span style="text-align:right; font-family: 'Ubuntu', sans-serif; margin-left: 77%;">Firma del cliente</span>      
        </div>
        
        <br />
        <br />
        
        <footer class="footer">
            <div style="width:100%; background-color:#432418;">
            <p style="color:#fff; font-family: 'Ubuntu'; padding: 1.5%; font-size: 9pt; text-align: justify;">
            En virtud a lo establecido en la Ley 29733, Ley de Protección de Datos Personales, 
            y el Decreto Supremo N° 003-2013-JUS, por el que se aprueba su Reglamento, 
            EL INTERESADO manifiesta expresamente su consentimiento para que sus datos personales 
            sean incorporados en los bancos de datos de titularidad de las empresas del Grupo Centenario, 
            almacenados en el domicilio de LA EMPRESA, y para: (i) enviarle publicidad de los distintos proyectos 
            de urbanizaciones y demás negocios del Grupo Centenario; (ii) perfilar a los clientes a los clientes y 
            desarrollar estrategias comerciales y de marketing; (iii) transferir su información a las distintas unidades de 
            negocio del Grupo Centenario; (v) transferir su información a proveedores estratégicos del Grupo Centenario. 
            Asimismo, EL INTERESADO declara conocer la Política de Privacidad de LA EMPRESA que además 
            se encuentra establecida en la web <strong>www.centenario.com.pe</strong>; pudiendo ejercer los derechos de la Ley de 
            Protección de Datos Personales enviado una solicitud a <strong>derechosarco@centenario.com.pe</strong>.  
            </p> 
            </div>                      
        </footer>
        
    </body>
    
