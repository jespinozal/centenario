            'S/.20000.00', 'S/.1000.00', 'S/.1500.00', '01/01/2025', 
            '12', 'S/.300000.00', 'S/.50000.00', 'S/.250000.00', 
            'S/.10000.00', 'S/.12000.00', '5', casoTest.Id,'','','','','','','','',''
        );

        System.assertNotEquals(base64Pdf, null, 'El PDF en base64 no debería ser nulo');
    }
