@isTest
public with sharing class CEN_SimularPrepago_test {
    @testSetup
    static void makeData() {
        // Crear un caso de prueba
        Case casoTest = new Case(
            CEN_TipoDePrepago__c            = 'Mantener Cuota',
            CEN_ImporteDeFinanciamiento__c = 20000,
            CEN_EstadoSAP__c = 'Completado',
            CEN_EstadoFinanciamiento__c = 'A',
            CEN_CodFinanciamiento__c = 'FIN001',
            CEN_VersionFinanciamiento__c = '1'
        );
        insert casoTest;
    }
    @isTest
    static void testGetResumenFinanciamiento() {
        // Obtener el caso insertado en testSetup
        Case casoTest = [SELECT Id FROM Case LIMIT 1];

        // Llamar al método y verificar el resultado
        CEN_SimularPrepago.Prepago resultado = CEN_SimularPrepago.getResumenFinanciamiento(casoTest.Id);
        System.assertNotEquals(resultado, null, 'El resultado no debería ser nulo');
        //System.assertEquals(resultado.importeFinanciamiento, 20000, 'El importe de financiamiento debería ser 20000');
        System.assertEquals(resultado.tipoDePrepago, 'Mantener Cuota', 'El tipo de prepago debería ser Mantener Cuota');
    }

    @isTest
    static void testGetResumenCuotas() {
        Test.startTest();
        // Obtener el caso insertado en testSetup
        Case casoTest = [SELECT Id FROM Case LIMIT 1];
        CEN_SimularPrepago.responseSimulacionTest       =   jsonResponse;
        // Llamar al método y verificar el resultado
        CEN_SimularPrepago.SimulacionDePrepago simulacion = CEN_SimularPrepago.getResumenCuotas(
            'simularPrepagoRadio', 'mantenerCuotaRadio', casoTest.Id, 20000 , date.today(),'','');
        Test.stopTest();
        System.assertNotEquals(simulacion, null, 'La simulación no debería ser nula');
        //System.assertEquals(simulacion.importeSimulado, 'S/.20000.00', 'El importe simulado debería estar formateado correctamente');
    }
