    static void testCEN_SimularPrepago(){
        Test.startTest();
        Case casoTest = [SELECT Id FROM Case LIMIT 1];
        PageReference pagina = Page.CEN_SimularPrepagoPdf;
        pagina.getParameters().put('importeSimulado', 'S/.20000.00');
        pagina.getParameters().put('cuotaActual', 'S/.1000.00');
        pagina.getParameters().put('nuevaCuota', 'S/.1500.00');
        pagina.getParameters().put('fechaDeTermino', '2024-12-31');
        pagina.getParameters().put('totalDeCuotas', '10');
        pagina.getParameters().put('precioDeVentas', 'S/.100000.00');
        pagina.getParameters().put('capitalAmortizado', 'S/.5000.00');
        pagina.getParameters().put('saldoDeCapital', 'S/.15000.00');
        pagina.getParameters().put('prepago', 'S/.5000.00');
        pagina.getParameters().put('ultimaCuota', 'S/.1500.00');
        pagina.getParameters().put('cuotasPorPagar', '5');
        pagina.getParameters().put('idCaso', [SELECT Id FROM Case LIMIT 1].Id);

        Test.setCurrentPage(pagina);

        // Invocar el constructor
        CEN_SimularPrepago simularPrepago = new CEN_SimularPrepago();

        Test.stopTest();
    }
