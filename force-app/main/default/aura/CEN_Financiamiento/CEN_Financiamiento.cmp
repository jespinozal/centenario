                                                          {!item.FechaAlterna}
                                                      </aura:if>
                                                  </td>
                                                  <td data-label="Fecha pago">
                                                     <aura:if isTrue="{!item.FechaPago!='0000-00-00'}">
                                                         {!item.FechaPago}
