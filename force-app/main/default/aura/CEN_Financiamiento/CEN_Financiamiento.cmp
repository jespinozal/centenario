                                                  </td>
                                                  <td data-label="Saldo inicial">
                                                      <ui:outputNumber format="#,###,###,##0.00############" value="{!item.SaldoInicial}"/>
                                                  </td>
                                                  <td data-label="Imp. Amort">
                                                      <ui:outputNumber format="#,###,###,##0.00############" value="{!item.Amortizacion}"/>
                                                  </td>
                                                  <td data-label="Imp Interes">
                                                      <ui:outputNumber format="#,###,###,##0.00############" value="{!item.Intereses}"/>
                                                  </td><!--
