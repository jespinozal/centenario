<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction"
                access="global" 
                controller="CEN_cls_Financiamiento">
    <aura:attribute name="recordId" type="String" default="0010v00000UC4c2AAD"/>
    <aura:attribute name="cuenta" type="Object" default="{}"/>
    <aura:attribute name="mydata" type="Object" default="{}"/>
    <aura:attribute name="data" type="List" default="[]"/>
    <aura:attribute name="mycolumns" type="List" default="[]"/>
    <aura:attribute name="lotes" type="List" default="[]"/>
    <aura:attribute name="mensaje" type="String"  default=""/>
    <aura:attribute name="total_financiamientos" type="Integer" default="0"/>
    <!--DETALLE FINANCIAMIENTO-->
    <aura:attribute name="proforma" type="Object" default=""/>
    <aura:attribute name="proformaDetalles" type="Object" default=""/>
    <aura:attribute name="CurrentUser" type="Object"/>
    <force:recordData recordId="{!$SObjectType.CurrentUser.Id}"
                  fields="Profile.Name"
                  targetFields="{!v.CurrentUser}"/>
    <aura:attribute name="lotesProforma" type="List" default="[]"/>
    <aura:attribute name="verFinanciamientos" type="Boolean" default="false"/>
    <aura:attribute name="verDetalle" type="Boolean" default="false"/>
    <aura:attribute name="verCampo" type="Boolean" default="true"/>
    <aura:attribute name="loaded" type="Boolean" default="true"/>
    <aura:attribute name="activeProfile" type="Boolean" default="false"/>

    <!--MOD FINANCIAMIENTO-->
    <aura:attribute name="localidad" type="String" default=""/>
    <aura:attribute name="kardex" type="String" default=""/>
    <aura:attribute name="notaria" type="String" default=""/>
    <aura:attribute name="partida" type="String" default=""/>
    <aura:attribute name="fecha" type="String" default=""/>
    
   	<aura:attribute name="activeSections" type="List" default="[]" />
    <aura:attribute name="activeSectionsMessage" type="String" default="" />
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <lightning:card title="{!'Financiamientos ('+v.total_financiamientos+')'}" iconName="standard:buyer_account" >
        <div aura:id="last-financiamiento" class="slds-hide slds-p-horizontal_small">
        <aura:iteration items="{!v.data}" var="item">
            <article class="slds-tile">
                <h3 class="slds-truncate" >
                    <a>
                        <lightning:button variant="base" label="{!item.proforma.PROFORMA +' - '+ item.proforma.VERSION}" value="{!item}" onclick="{! c.verDetalle }"/>
                    </a>
                </h3>
                <div class="slds-tile__detail">
                  <dl class="slds-list_horizontal slds-wrap">
                    <dt class="slds-item_label slds-text-color_weak slds-truncate">Proyecto:</dt>
                    <dd class="slds-item_detail slds-truncate">{!item.proforma.PROYECTO_TEXT}</dd>
                    <dt class="slds-item_label slds-text-color_weak slds-truncate">Precio:</dt>
                    <dd class="slds-item_detail slds-truncate"><ui:outputNumber format="#,###,###,##0.00############" value="{!item.proforma.PRECIO}"/>
                        <ui:outputText value="{!' '+item.proforma.WAERS}"/></dd>
                    <dt class="slds-item_label slds-text-color_weak slds-truncate">Fecha Cierre Venta:</dt>
                    <dd class="slds-item_detail slds-truncate">
                        <aura:if isTrue="{!item.proforma.FECHA_CVENTAS!='0000-00-00'}">
                            <ui:outputDate format="EEE, d MMM yyyy" value="{!item.proforma.FECHA_CVENTAS}"/>
                        </aura:if>
                      </dd>
                  </dl>
                </div>
              </article>
        </aura:iteration>
        </div>
         <aura:set attribute="footer">
             <aura:if isTrue="{!v.total_financiamientos!=0}">
               <div class="slds-text-align_center">
                   <a href="javascript:void(0)" onclick="{!c.verTodos}">
                       Ver todos
                   </a>
               </div>
             </aura:if>
         </aura:set>       
    </lightning:card>
    <aura:if isTrue="{!v.verFinanciamientos}">
        <div aura:id="modal-tiene-financiamiento">
      <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" 
               aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open slds-modal_large">
                <div class="slds-modal__container">
                    <!-- Modal/Popup Box Header Starts here-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{! c.Cerrar }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"/>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate"><strong>Financiamientos del cliente</strong></h2>
                    </header>
                    
                   <!--Modal/Popup Box Body Starts here-->
                   <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">                      
                 	<!--****************************************************** Cabecera del Componente *****************************************************************--> 
                       <div class="table_body_cabecera">
                           <!--<table class="slds-table slds-table_cell-buffer slds-table_bordered slds-table_col-bordered">-->
                           <table class="slds-table slds-table_cell-buffer slds-no-row-hover slds-table_bordered slds-table_col-bordered slds-text-body_small">
                               <thead>
                                   <tr class="slds-line-height_reset">
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Proyecto">Proyecto</div>
                                       </th>
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Fecha de cierre de ventas">F. Cierre de ventas</div>
                                       </th>
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Cantidad de Lotes">Lotes</div>
                                       </th>
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Información de los lotes">Mz.Lt.</div>
                                       </th>
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Sociedad">Sociedad</div>
                                       </th>
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Financiamiento N°">Financiamiento N°</div>
                                       </th>
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Versión">Versión</div>
                                       </th>
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Estado del Financiamiento">Est. Financiamiento</div>
                                       </th>
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Fecha de Inactividad">Fecha Inactividad</div>
                                       </th>
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Motivo">Motivo</div>
                                       </th>
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Moneda Lote">Moneda Lote</div>
                                       </th>
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Descripción Vía Financiamiento">Descripción Vía Financiamiento</div>
                                       </th>
                                       <th class="" scope="col">
                                           <div class="slds-truncate" title="Descripción Vía Financiamiento">Ver detalles</div>
                                       </th>
                                   </tr>
                               </thead>
                               <tbody>
                                   <aura:iteration items="{!v.mydata}" var="item">
                                   <tr class="slds-hint-parent">
                                       <td data-label="Proyecto">
                                           <div class="slds-truncate" title="{!item.proforma.PROYECTO_TEXT}">
                                               <ui:outputText value="{!item.proforma.PROYECTO_TEXT}"/>                                           
                                           </div>
                                       </td>
                                       <td data-label="F. Cierre de ventas">
                                           <div class="slds-truncate" title="{!item.proforma.FECHA_CVENTAS}">
                                               <aura:if isTrue="{!item.proforma.FECHA_CVENTAS!='0000-00-00'}">
                                                   <ui:outputDate format="EEE, d MMM yyyy" value="{!item.proforma.FECHA_CVENTAS}"/>
                                               </aura:if>                                        
                                           </div>
                                       </td>
                                        <td data-label="Lotes">
                                           <div class="slds-truncate" title="{!item.CantidadLotes}">
                                               <ui:outputText value="{!item.CantidadLotes}"/>                                           
                                           </div>
                                       </td>
                                       <td data-label="Mz.Lt">
                                           <div class="slds-truncate" title="{!item.LotesConcatenado}">
                                               <ui:outputText value="{!item.LotesConcatenado}"/>                                           
                                           </div>
                                       </td>
                                       <td data-label="Sociedad">
                                           <div class="slds-truncate" title="{!item.proforma.BUKRS}">
                                               <ui:outputText value="{!item.proforma.BUKRS}"/>                                           
                                           </div>
                                       </td>
                                       <td data-label="Financiamiento N°">
                                           <div class="slds-truncate" title="{!item.proforma.PROFORMA}">
                                               <ui:outputText value="{!item.proforma.PROFORMA}"/>                                           
                                           </div>
                                       </td>
                                        <td data-label="Versión">
                                           <div class="slds-truncate" title="{!item.proforma.VERSION}">
                                               <ui:outputText value="{!item.proforma.VERSION}"/>                                           
                                           </div>
                                       </td>
                                       <td data-label="Est. Financiamiento">
                                           <div class="slds-truncate" title="{!item.proforma.ESTADO}">
                                               <ui:outputText value="{!item.proforma.ESTADO}"/>                                           
                                           </div>
                                       </td>
                                        <td data-label="Fecha Inactividad">
                                           <div class="slds-truncate" title="{!item.proforma.FECHA_INACTIVO}">
                                               <ui:outputText value="{!item.proforma.FECHA_INACTIVO}"/>                                           
                                           </div>
                                       </td>
                                       <td data-label="Motivo">
                                           <div class="slds-truncate" title="{!item.proforma.MOTIVO}">
                                               <ui:outputText value="{!item.proforma.MOTIVO}"/>                                           
                                           </div>
                                       </td>
                                       <td data-label="Moneda Lote">
                                           <div class="slds-truncate" title="{!item.proforma.WAERS}">
                                               <ui:outputText value="{!item.proforma.WAERS}"/>                                           
                                           </div>
                                       </td>
                                       <td data-label="Descripción Vía Financiamiento">
                                           <div class="slds-truncate" title="{!item.proforma.VIAFINAN_TEXT}">
                                               <ui:outputText value="{!item.proforma.VIAFINAN_TEXT}"/>                                           
                                           </div>
                                       </td>
                                       <td data-label="Ver detalles">
                                           <div class="slds-truncate" title="Ver más detalles">
                                               <lightning:button variant="base" label="Ver detalles" value="{!item}" onclick="{! c.verDetalle }"/>                                           
                                           </div>
                                       </td>
                                   </tr>
                                   </aura:iteration>
                               </tbody>
                           </table>                           
                       </div>                                                    
                   <!--*************************************************************************************************************************************************--> 
                   </div>
                        <footer class="slds-modal__footer">
                           
                            <lightning:button variant="brand"
                                              label="Cerrar"
                                              title="Cerrar"
                                              onclick="{!c.Cerrar}"/>
                        </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
      
      
  </div>  
    </aura:if>
    <aura:if isTrue="{!v.verDetalle}">
        <div aura:id="modal-detalle-proforma">
      <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" 
               aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open slds-modal_large">
                <div class="slds-modal__container">
                    <!-- Modal/Popup Box Header Starts here-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{! c.CerrarDetalleProforma }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"/>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate"><b>Financiamiento <ui:outputText value="{!v.proforma.proforma.PROFORMA}"/></b></h2>                        
                    </header>                    
                   <!--Modal/Popup Box Body Starts here-->
                   <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">                       
                 	<!--****************************************************** Cabecera del Componente *****************************************************************--> 
                       <lightning:tabset selectedTabId="1">
                           <lightning:tab label="Detalle del financiamiento" id="1">
                               <div class="slds-grid slds-grid_vertical">
                                   <div class="slds-col">
                                       <div class="slds-grid">
                                           <div class="slds-col slds-size_1-of-2">
                                               <span>
                                                   <div class="slds-grid slds-grid_vertical slds-p-right_large">
                                                       <div class="slds-col slds-border_bottom">
                                                           <div class="slds-grid">
                                                               <div class="slds-col slds-size_2-of-3">N° Proforma</div>
                                                               <div class="slds-col slds-size_1-of-3 slds-text-align_right"><ui:outputText value="{!v.proforma.proforma.PROFORMA}"/></div>
                                                           </div>
                                                       </div>
                                                       <div class="slds-col slds-border_bottom">
                                                           <div class="slds-grid">
                                                               <div class="slds-col slds-size_2-of-3">Versión</div>
                                                               <div class="slds-col slds-size_1-of-3 slds-text-align_right"><ui:outputNumber format="#" value="{!v.proforma.proforma.VERSION}"/></div>
                                                           </div>
                                                       </div>
                                                       
                                                       <div class="slds-col slds-border_bottom">
                                                           <div class="slds-grid">
                                                               <div class="slds-col slds-size_2-of-3">Urbanización</div>
                                                               <div class="slds-col slds-size_1-of-3 slds-text-align_right"><ui:outputText value="{!v.proforma.proforma.PROYECTO_TEXT}"/></div>
                                                           </div>
                                                       </div>
                                                       <div class="slds-col slds-border_bottom">
                                                           <div class="slds-grid">
                                                               <div class="slds-col slds-size_2-of-3">Cod Propiedad</div>
                                                               <div class="slds-col slds-size_1-of-3 slds-text-align_right"><ui:outputText value="{!v.proforma.LotesConcatenado}"/></div>
                                                           </div>
                                                       </div>
                                                       <div class="slds-col slds-border_bottom">
                                                           <div class="slds-grid">
                                                               <div class="slds-col slds-size_2-of-12">Cliente</div>
                                                               <div class="slds-col slds-size_3-of-12 slds-text-align_right">
                                                                   <aura:if isTrue="{!v.cuenta.RecordType.Name!='Cuenta Natural'}">
                                                                         {!v.cuenta.CEN_Numero_de_documento_del__c}
                                                                         <aura:set attribute="else">
                                                                             {!v.cuenta.CEN_N_mero_de_documento__pc}
                                                                         </aura:set>
                                                                   </aura:if> 
                                                               </div>
                                                               <div class="slds-col slds-size_7-of-12 slds-text-align_right">{!v.cuenta.Name}</div>
                                                           </div>
                                                       </div>
                                                   </div>
                                               </span>
                                           </div>
                                            <div class="slds-col slds-size_1-of-2">
                                               <span>
                                                   <div class="slds-grid slds-grid_vertical">
                                                       <div class="slds-col slds-border_bottom">
                                                           <div class="slds-grid">
                                                               <div class="slds-col slds-size_8-of-12">Precio venta</div>
                                                               <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00######" value="{!v.proforma.proforma.PRECIO}"/></div>
                                                               <div class="slds-col slds-size_1-of-12 slds-text-align_right">{!v.proforma.proforma.WAERS}</div>
                                                           </div>
                                                       </div>
                                                       <div class="slds-col slds-border_bottom">
                                                           <div class="slds-grid">
                                                               <div class="slds-col slds-size_8-of-12">PVP/m<sup>2</sup></div>
                                                               <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00######" value=""/></div>
                                                               <div class="slds-col slds-size_1-of-12 slds-text-align_right">{!v.proforma.proforma.WAERS}</div>
                                                           </div>
                                                       </div>
                                                       <div class="slds-col slds-border_bottom">
                                                           <div class="slds-grid">
                                                               <div class="slds-col slds-size_8-of-12">Importe amortizado</div>
                                                               <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00######" value="{!v.proforma.proforma.AMORTIZADO}"/></div>
                                                               <div class="slds-col slds-size_1-of-12 slds-text-align_right">{!v.proforma.proforma.WAERS}</div>
                                                           </div>
                                                       </div>
                                                       <div class="slds-col slds-border_bottom">
                                                           <div class="slds-grid">
                                                               <div class="slds-col slds-size_2-of-3">Fecha cierre ventas</div>
                                                               <div class="slds-col slds-size_1-of-3 slds-text-align_right">
                                                                   <aura:if isTrue="{!v.proforma.proforma.FECHA_CVENTAS!='0000-00-00'}">
                                                                       <ui:outputDate format="EEE, d MMM yyyy" value="{!v.proforma.proforma.FECHA_CVENTAS}"/>
                                                                   </aura:if>
                                                               </div>
                                                           </div>
                                                       </div>
                                                       <div class="slds-col">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-border_bottom slds-p-right_small slds-size_7-of-12">
                                                           <div class="slds-grid">
                                                           <div class="slds-col slds-size_2-of-3">
                                                               Vía financiamiento
                                                           </div>
                                                           <div class="slds-col slds-size_1-of-2 slds-text-align_center">
                                                               {!v.proforma.proforma.VIA_FINANCIAMIENTO}
                                                           </div>
                                                           </div>
                                                       </div>
                                                       <div class="slds-col slds-size_1-of-12"> </div>
                                                       <div class="slds-col slds-border_bottom slds-size_4-of-12">
                                                           <div class="slds-grid">
                                                           <div class="slds-col slds-size_1-of-2">
                                                               Medio
                                                           </div>
                                                           <div class="slds-col slds-size_1-of-2 slds-text-align_right">
                                                               {!v.proforma.proforma.MEDIO}
                                                           </div>
                                                           </div>
                                                       </div>
                                                   </div>
                                               </div>
                                                   </div>
                                                </span>
                                           </div>
                                       </div>
                                   </div>
                                   <div class="slds-col slds-p-top_medium">
                                       <span>
                                            <div class="table_body_short">                               
                                  <table class="slds-table slds-table_cell-buffer slds-no-row-hover slds-table_bordered slds-text-body_small">
                                      <thead>
                                          <tr class="slds-line-height_reset">
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Número de Cuota">N° Cuota</div>
                                              </th><!--
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Cuota auxiliar">Cuota aux</div>
                                              </th>-->
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Tipo de cuota">Tipo cuota</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Saldo inicial">Saldo inicial</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Importe amortizado">Imp. Amortizado</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Importe intereses">Imp. Interes</div>
                                              </th><!--
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Gastos">Gastos</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Intereses + gastos administrativos">IntGasAdm</div>
                                              </th>-->
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Importe de la cuota">Imp. de la cuota</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Moneda">Moneda</div>
                                              </th><!--
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Saldo final">Saldo final</div>
                                              </th>-->
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Fecha de vencimiento">F. vencimiento</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Fecha Alterna">F. Alterna</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Fecha de pago">Fecha pago</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Indicador de Pagado">¿Pagado?</div>
                                              </th>
                                              <!--
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Descuento">Descuento</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="No Dias">N° Dias</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="No Dias Acu">N° Dias Acu</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="IGV">IGV</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Desgravamen Desempleo">Dgv desempleo</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Desgravamen Desempleo">Dgv seguro vida</div>
                                              </th>
                                              
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Sociedad">Sociedad</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Número de un documento contable">N° doc. contable</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Ejercicio">Ejercicio</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Indicador devengado">¿Devengado?</div>
                                              </th>-->
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Indicador de Envío a banco">¿Envío a banco?</div>
                                              </th>
                                              <th class="" scope="col">
                                                  <div class="slds-truncate" title="Fecha de envío a banco">F. envío a banco</div>
                                              </th>
                                          </tr>
                                      </thead>
                                      <tbody>
                                          <aura:iteration items="{!v.proformaDetalles}" var="item">
