                                                                   <div class="slds-col slds-border_bottom">
                                                                       <div class="slds-grid">
                                                                           <div class="slds-col slds-size_8-of-12">Área primera venta</div>
                                                                           <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00######" value="{!lotep.AREA_VENDIBLE}"/></div>
