                                                       <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00############" value="{!v.proforma.proforma.OTROS_GASTOS_CLIENTE}"/></div>                                                       
                                                       <div class="slds-col slds-size_1-of-12 slds-text-align_right">{!v.proforma.proforma.WAERS}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">% cargos por cuenta del cliente</div>                                                       
                                                       <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00############" value="{!v.proforma.proforma.CARGOS_POR_CTA_CLIENTE}"/></div>
                                                       <div class="slds-col slds-size_1-of-12 slds-text-align_right">%</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Total descontar penalidad</div>                                                                                                              
                                                       <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00############" value="{!v.proforma.proforma.TOTAL_DESCONTAR_PENALIDAD}"/></div>                                                       
                                                       <div class="slds-col slds-size_1-of-12 slds-text-align_right">{!v.proforma.proforma.WAERS}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Monto nc cap pagado</div>                                                                                                              
                                                       <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00############" value="{!v.proforma.proforma.MONTO_NC_CAPITAL_PAGADO}"/></div>                                                       
                                                       <div class="slds-col slds-size_1-of-12 slds-text-align_right">{!v.proforma.proforma.WAERS}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Monto nc cap no pagado</div>                                                       
                                                       <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00############" value="{!v.proforma.proforma.MONTO_NC_CAPITAL_NO_PAGADO}"/></div>                                                       
                                                       <div class="slds-col slds-size_1-of-12 slds-text-align_right">{!v.proforma.proforma.WAERS}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Monto nc Int. pagado</div>                                                       
                                                       <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00############" value="{!v.proforma.proforma.MONTO_NC_INTERESES_PAGADO}"/></div>                                                       
                                                       <div class="slds-col slds-size_1-of-12 slds-text-align_right">{!v.proforma.proforma.WAERS}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Monto nc Int. no pagado</div>                  
                                                       <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00############" value="{!v.proforma.proforma.MONTO_NC_INTERESES_NO_PAGADO}"/></div>                                                       
                                                       <div class="slds-col slds-size_1-of-12 slds-text-align_right">{!v.proforma.proforma.WAERS}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Monto nc penalidad</div>                       
                                                       <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00############" value="{!v.proforma.proforma.MONTO_NC_PENALIDAD}"/></div>                                                       
                                                       <div class="slds-col slds-size_1-of-12 slds-text-align_right">{!v.proforma.proforma.WAERS}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Flag variación de área</div>                                                       
                                                       <div class="slds-col slds-size_4-of-12 slds-text-align_right">{!v.proforma.proforma.FLAG_VARIACION_AREA}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Variación de Área</div>                                                       
                                                       <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00######" value="{!v.proforma.proforma.METROS_VARIACION_AREA}"/></div>
                                                       <div class="slds-col slds-size_1-of-12 slds-text-align_right">m<sup>2</sup></div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Monto de variación de área</div>                                                       
                                                       <div class="slds-col slds-size_3-of-12 slds-text-align_right"><ui:outputNumber format="#,###,###,##0.00############" value="{!v.proforma.proforma.MONTO_VARIACION_AREA}"/></div>
                                                       <div class="slds-col slds-size_1-of-12 slds-text-align_right">%</div>
                                                   </div>
                                               </div>
                                           </div>
                                       </span>
                                   </div>
                               </div>
                               <div class="slds-grid slds-p-top_large">
                                   <div class="slds-col slds-col slds-size_1-of-3">
                                       <span>
                                           <div class="slds-grid slds-grid_vertical slds-p-right_large">
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Número de asignación</div>
                                                       <div class="slds-col slds-size_4-of-12 slds-text-align_right">{!v.proforma.proforma.ZAC_DOC_SUNAT}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Saldo: nº de cuotas</div>
                                                       <div class="slds-col slds-size_4-of-12 slds-text-align_right"><ui:outputNumber format="#" value="{!v.proforma.proforma.NCUOTAS_SALDO_ORIGINAL}"/></div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Código de motivo</div>
                                                       <div class="slds-col slds-size_4-of-12 slds-text-align_right">{!v.proforma.proforma.MOTIVO_COMPRA}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Asiento de apoderado comprador 1</div>
                                                       <div class="slds-col slds-size_4-of-12 slds-text-align_right">{!v.proforma.proforma.ASIENTOAP1}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Asiento de apoderado comprador 2</div>
                                                       <div class="slds-col slds-size_4-of-12 slds-text-align_right">{!v.proforma.proforma.ASIENTOAP2}</div>
                                                   </div>
                                               </div>
                                           </div>
                                       </span>
                                   </div>
                                   <div class="slds-col slds-col slds-size_2-of-3">
                                       <span>
                                           <div class="slds-grid slds-grid_vertical slds-p-right_large">
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Cambiante de situacion financiera a compromiso de pago</div>
                                                       <div class="slds-col slds-size_4-of-12 slds-text-align_right">{!v.proforma.proforma.USRCOMPPAGO}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Status de aprobación de firma electrónica</div>
                                                       <div class="slds-col slds-size_4-of-12 slds-text-align_right">{!v.proforma.proforma.ESIGN_ESTADO}</div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Fecha de aprobación de firma electrónica</div>
                                                       <div class="slds-col slds-size_1-of-3 slds-text-align_right">
                                                           <aura:if isTrue="{!v.proforma.proforma.ESIGN_FECHA!='0000-00-00'}">
                                                               <ui:outputDate format="EEE, d MMM yyyy" value="{!v.proforma.proforma.ESIGN_FECHA}"/>
                                                           </aura:if>
                                                       </div>
                                                   </div>
                                               </div>
                                               <div class="slds-col slds-border_bottom">
                                                   <div class="slds-grid">
                                                       <div class="slds-col slds-size_8-of-12">Clave referencia 1 interna para cabecera documento</div>
                                                       <div class="slds-col slds-size_4-of-12 slds-text-align_right">{!v.proforma.proforma.COMPROB_ORACLE}</div>
                                                   </div>
                                               </div>
                                           </div>
                                       </span>
                                   </div>
                               </div>                                               
                           </lightning:tab>
                       </lightning:tabset>
                   <!--*************************************************************************************************************************************************-->                     
                       </div>
                        <footer class="slds-modal__footer">
                            <aura:if isTrue="{!v.verCampo}">
                                <aura:set attribute="else">
                                    <!-- <aura:iteration items="{!v.data}" var="item"> -->
                                    <lightning:button variant="brand"
                                                    label="Guardar"
                                                    title="Guardar"
                                                    onclick="{!c.SaveFinancing}"/>
                                    <!-- </aura:iteration> -->
                                </aura:set>
                            </aura:if>

                            <lightning:button variant="brand"
                                            label="Cerrar"
                                            title="Cerrar"
                                            onclick="{!c.CerrarDetalleProforma}"/>

                        </footer>

                        <aura:if isTrue="{!v.loaded}">
                            <div class="slds-spinner_container">
                                <lightning:spinner alternativeText="Loading" size="medium" />
                            </div>
                        </aura:if> 
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>    
    </div>
    </aura:if>

</aura:component>