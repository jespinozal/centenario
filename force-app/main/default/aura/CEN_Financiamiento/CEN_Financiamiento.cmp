                                                              <ui:outputNumber value="{!item.Igv}" format="#,###,###,##0.00############"/>
                                                  </td>
                                                          <td data-label="Desgravamen Desempleo">
                                                              <ui:outputNumber value="{!item.Desempleo}" format="#,###,###,##0.00############" />
                                                  </td>
                                                          <td data-label="Dgv seguro vida">
                                                              <ui:outputNumber value="{!item.SeguroVida}" format="#,###,###,##0.00############" />
                                                  </td>
                                                          
                                                          <td data-label="Sociedad">
                                                               {!item.BUKRS}
                                                  </td>
                                                          <td data-label="Número de un documento contable">
                                                               {!item.Belnr}
                                                  </td>
                                                          <td data-label="Ejercicio">
                                                               {!item.Gjahr}
                                                  </td>
                                                          <td data-label="Indicador devengado">
                                                               {!item.FlagDevengado}
                                                  </td>-->
                                                          <td data-label="Indicador Envío a banco">
                                                               {!item.FlagEnvioBanco}
                                                  </td>
                                                          <td data-label="Fecha Alterna">
                                                              <aura:if isTrue="{!item.FechaEnvioBanco!='0000-00-00'}">
                                                          {!item.FechaEnvioBanco}
                                                      </aura:if>
                                                  </td>
                                              </tr>
                                                   <aura:set attribute="else">
                                                       <tr class="slds-hint-parent">
                                                  <td data-label="N° Cuota">
                                                      <ui:outputNumber format="#" value="{!item.Cuota}"/>
                                                  </td><!--
                                                  <td data-label="Cuota aux">
                                                      <ui:outputNumber format="#" value="{!item.CuotaAux}"/>
                                                  </td>-->
                                                  <td data-label="Tipo cuota">
