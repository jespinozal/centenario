                                                     {!item.FlagPagado}
                                                  </td><!--
                                                  <td data-label="No Dias">
                                                     {!item.NoDias}
                                                  </td>
                                                          <td data-label="No Dias Acu">
                                                     {!item.NoDiasAcu}
                                                  </td>
