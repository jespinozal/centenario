                                  <div class="slds-col ">
                                       <article class="slds-card ">
                                           <div class="slds-card__body slds-card__body_inner">
                                                <strong>DATOS DE ADQUISICIÓN</strong>
                                                <div class="slds-grid slds-grid_vertical">
                                                    <div class="slds-col">
                                                        <div class="slds-grid">
                                                            <div class="slds-col slds-size_1-of-2">
                                                                <span>
                                                                    <div class="slds-grid slds-grid_vertical slds-p-right_large">
                                                                        <div class="slds-col slds-border_bottom">
                                                                            <div class="slds-grid">
                                                                                <div class="slds-col slds-size_2-of-3">Nombre de la Notaria</div>
