                                                  </td>
                                                  <td data-label="IntGasAdm">
                                                      <ui:outputNumber format="#,###,###,##0.00############" value="{!item.InteresGastos}"/>
                                                  </td>-->
                                                  <td data-label="Imp cuota">
                                                      <ui:outputNumber format="#,###,###,##0.00############" value="{!item.ImpCuota}"/>
                                                  </td>
                                                  <td data-label="Moneda">
                                                     {!item.Waers}
                                                  </td><!--
                                                  <td data-label="Saldo final">
                                                     <ui:outputNumber format="#,###,###,##0.00############" value="{!item.SaldoFinal}"/>
                                                  </td>-->
                                                  <td data-label="Fec. Venc.">
                                                     <aura:if isTrue="{!item.FechaVencimiento!='0000-00-00'}">
                                                          {!item.FechaVencimiento}
