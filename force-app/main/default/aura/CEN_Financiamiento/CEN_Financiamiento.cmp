                                                                                    <div class="slds-col slds-size_1-of-3 slds-text-align_right"><ui:outputText value="{!v.proforma.proforma.NOMBRE_NOTARIO}"/></div>
                                                                                    <aura:if isTrue="{!v.activeProfile}">
                                                                                        <lightning:buttonIcon iconName="utility:edit" onclick="{!c.showHide}" class="slds-col_bump-left" iconClass="slds-button__icon_hint" variant="bare" alternativeText="Edit Records" /> 
                                                                                    </aura:if>
                                                                                <aura:set attribute="else">
