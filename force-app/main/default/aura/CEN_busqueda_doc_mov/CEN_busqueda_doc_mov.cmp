<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes" access="global" controller="CEN_busquedaDNI" >
		
    	<aura:attribute name="searchResult" type="List" description="use for store and display account list return from server"/>
    	<aura:attribute name="isModaldoc" type="boolean" default="false"/>
  		
    
    <br/><br/>
    
        <div align="center" style="background-color: white">
            <br/><br/>
          	<lightning:layoutItem size="9" padding="around-medium">    
                        <lightning:select name="documento"                                            
                                          label="Tipo de Documento"
                                          required="true"
                                          onchange="{!c.changeitem}"
                                          aura:id="documento">
                        <option value="DNI">DNI</option>
                        <option value="RUC">RUC</option>
                        <option value="PTP">PTP</option>
                        <option value="Pasaporte">Pasaporte</option>
                        <option value="Carnet de extranjeria">Carnet de extranjeria</option>
                        
                        </lightning:select>
        	</lightning:layoutItem>                 
            
            <lightning:layoutItem size="9" padding="around-small">
                        <lightning:input name="numero"										                                        
                                         required="true"
                                         placeholder="Ingresar Nº de documento ..."
                                         aura:id="numero"
                                         onchange="{!c.changevalor}"
                                         label="Nº de documento"/>
                    	</lightning:layoutItem>
            
            <lightning:layoutItem size="7" padding="around-small">
                        <lightning:button onclick="{!c.Search}"
                                          variant="brand"
                                          label="Buscar"
                                          iconName="utility:search"/> 
          	</lightning:layoutItem>
            <br/><br/>
      	</div>
   
    <!--************************************************************************  MODAL Nº Doc Encontrado  *********************************************************************-->  
    	<!--Use aura:if tag to display/hide popup based on isModalOpen value-->  
        <aura:if isTrue="{!v.isModaldoc}">
            
            <!-- Modal/Popup Box starts here-->
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- Modal/Popup Box Header Starts here-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{! c.closeModelDoc }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"/>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">Nro de Documento Registrado</h2>
                    </header>
                    
                   <!--Modal/Popup Box Body Starts here-->
                   <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1"> 
                       
                 	<!--****************************************************** Cabecera del Componente *****************************************************************--> 
                       <aura:iteration items="{!v.searchResult}" var="acc" >
                                <td >El Nº de documento ya se encuentra registrado le pertenece a {!acc.Name}.
                                </td>
                      	</aura:iteration>
                   <!--*************************************************************************************************************************************************--> 
                   </div>
                        <!--Modal/Popup Box Footer Starts here-->
                        <footer class="slds-modal__footer">
                           
                            <lightning:button variant="brand"
                                              label="Redirigir"
                                              title="Redirigir"
                                              onclick="{!c.redModelDoc}"/>
                        </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
     	</aura:if>
    
</aura:component>