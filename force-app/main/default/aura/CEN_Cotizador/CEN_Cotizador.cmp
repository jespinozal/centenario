    <!-- ESCENARIOS DE FINANCIAMIENTO -->
    <aura:if isTrue="{!v.secEscenarioFin}">
        <!-- Header -->
        <div
            class="slds-page-header slds-m-bottom_xx-small"
            style="color:#ffffff; background-color:#1b5297"
        >
            <div class="slds-page-header__title slds-text-heading_small">
                Escenarios de financiamiento
                <div class="slds-float_right slds-text-heading_small">
                    <lightning:button
                        variant="Neutral"
                        label="Calcular Escenarios"
                        title="Calcular Escenarios"
                        onclick="{!c.getPeriodos}"
                        disabled="{!v.disabledPeriodos}"
                    />
                </div>
            </div>
        </div>
        <!-- TABLA -->
        <!-- <aura:if isTrue="{!not(v.isLoading)}"> -->
            <table
                class="slds-table slds-table_cell-buffer
                      slds-table_bordered slds-table_col-bordered
                      slds-p-vertical_xxx-small"
                style="width:100%"
            >
                <thead>
                    <tr>
                        <th scope="col">
                            <div class="slds-truncate slds-text-align_center">
                                Cuotas por
                            </div>
                        </th>
                        <th scope="col">
                            <div class="slds-truncate slds-text-align_center">
                                Montos
                            </div>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <aura:iteration items="{!v.listaFinanciamiento}" var="elemento">
                        <tr>
                            <td style="width:20%">
                                <div class="slds-truncate slds-text-align_center">
                                    <ui:inputNumber
                                        class="slds-input slds-text-align_center myinput"
                                        format="## Años"
                                        value="{!elemento.anio}"
                                        disabled="true"
                                    />
                                </div>
                            </td>

                            <td style="width:20%">
                                <div class="slds-truncate slds-text-align_center">
                                    <aura:if isTrue="{!elemento.monto == 0}">
                                        <span class="slds-text-color_error slds-text-body_small">
                                            {!elemento.mensajeError}
                                        </span>
                                        <aura:set attribute="else">
                                            <span>S/ </span>
                                            <lightning:formattedNumber
                                                value="{!elemento.monto}"
                                                minimumFractionDigits="2"
                                                maximumFractionDigits="2"
                                            />
                                        </aura:set>
                                    </aura:if>
                                </div>
                            </td>
                        </tr>
                    </aura:iteration>
                </tbody>
            </table>
        <!-- </aura:if> -->
    </aura:if>
    <!-- FIN ESCENARIOS DE FINANCIAMIENTO -->
  </div>

  <c:wcCEN_MessagePopUpWarning
    aura:id="childLwcCompId"
  ></c:wcCEN_MessagePopUpWarning>

  <aura:if isTrue="{!v.proforma==null}">
    <c:lwcSimuladorPrepago
      aura:id="childSimuladorPrepago"
      recordId="{!v.IdOportunidad}"
      IdOportunidad="{!v.IdOportunidad}"
      fecCuotaSaldoIni="{!v.fecCuotaSaldoIni}"
      fecCuotaSaldoFin="{!v.fecCuotaSaldoFin}"
      numCuotas="{!v.numCuotas}"
      monotocuotafinan="{!v.monotocuotafinan}"
    />
  </aura:if>

  <c:lwcGestionDescuento
    aura:id="childGestionDescuento"
    recordId="{!v.IdOportunidad}"
    IdOportunidad="{!v.IdOportunidad}"
    listDiscount="{!v.listDiscount}"
    listPalanca="{!v.listPalanca}"
    listMessage="{!v.listMessage}"
    hasPermission="{!v.hasPermission}"
    hasPermissionAdditional="{!v.hasPermissionAdditional}"
    onvaluechange="{!c.getValueFromLwc}"
  />
</aura:component>