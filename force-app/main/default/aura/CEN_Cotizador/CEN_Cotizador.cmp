            </th>
            <th scope="col ">
              <div class="slds-truncate slds-text-align_center">
                Monto de cuota
              </div>
            </th>
            <th scope="col ">
              <div class="slds-truncate slds-text-align_center">
                Descripción
              </div>
            </th>
          </tr>
        </thead>
        <tbody>
          <aura:iteration items="{!v.inpAnotaciones}" var="obj">
            <tr>
              <td scope="col slds-text-align_center" style="width: 5%">
                <div class="slds-truncate" style="text-align: center">
