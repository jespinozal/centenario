      >
        <div class="slds-page-header__title slds-text-heading_small">
          Anotaciones
        </div>
      </div>
      <table
        class="slds-table slds-table_cell-buffer slds-table_bordered slds-table_col-bordered slds-p-vertical_xxx-small"
        style="width: 100%"
      >
        <thead>
          <tr class="">
